# Copy to backend/.env.qa or backend/.env.prod and fill in values.
# Never commit files with real values.

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

GEMINI_API_KEY=
LINKD_API_KEY=

UPSTASH_REDIS_URL=https://<db>.upstash.io
UPSTASH_REDIS_TOKEN=

RESEND_API_KEY=

ENVIRONMENT=qa        # "qa" or "prod"
LOG_LEVEL=DEBUG       # "DEBUG" for qa, "INFO" for prod
